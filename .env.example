# ── API ──────────────────────────────────────────────────────────────────────
# Requerido: API Key de Google Gemini
GEMINI_API_KEY="tu_api_key_aqui"

# ── Modelo ───────────────────────────────────────────────────────────────────
# Opcional: Nombre del modelo a utilizar (por defecto: gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Opcional: Temperatura para la generación (por defecto: 0)
# TEMPERATURE="0"

# Opcional: Máximo de reintentos permitidos (por defecto: 8)
# MAX_RETRIES="8"

# Opcional: Demora base en segundos entre reintentos por error 429 de API (por defecto: 65.0)
# RETRY_BASE_DELAY="65.0"

# Opcional: Segundos de pausa entre PDFs consecutivos (por defecto: 15)
# INTER_PDF_COOLDOWN="15"

# ── Rutas ────────────────────────────────────────────────────────────────────
# Opcional: Carpeta donde leer los PDFs (por defecto: rcas)
# PDF_FOLDER="rcas"

# Opcional: Archivo de salida Excel (por defecto: rca_results.xlsx)
# OUTPUT_FILE="rca_results.xlsx"

# Opcional: Archivo maestro de variables SEIA (por defecto: seia-variables.xlsx)
# VARIABLES_FILE="seia-variables.xlsx"

# Opcional: Ruta para guardar/leer los checkpoints (por defecto: checkpoints/checkpoint.json)
# CHECKPOINT_FILE="checkpoints/checkpoint.json"

# Opcional: Ruta para el archivo de logs (por defecto: logs/extractor.log)
# LOG_FILE="logs/extractor.log"

# ── Procesamiento ────────────────────────────────────────────────────────────
# Opcional: Cantidad de workers concurrentes (por defecto: 1. Aumentar > 1 para procesar en paralelo)
# MAX_WORKERS="1"

# ── Configuración de Datos ───────────────────────────────────────────────────
# Opcional: Columna a buscar en el archivo de variables (por defecto: Variable Clave)
# VARIABLES_COLUMN="Variable Clave"

# ── Scraper SEIA ─────────────────────────────────────────────────────────────
# Opcional: Directorio donde se guardan los PDFs descargados (por defecto: data/raw/scraped)
# SCRAPED_DIR="data/raw/scraped"

# Opcional: Demora entre peticiones al portal (por defecto: 3.0)
# SCRAPER_DELAY="3.0"

# Opcional: Archivo de checkpoint del scraper (por defecto: checkpoints/scraper_checkpoint.json)
# SCRAPER_CHECKPOINT="checkpoints/scraper_checkpoint.json"

# Opcional: Archivo de logs del scraper (por defecto: logs/scraper.log)
# SCRAPER_LOG_FILE="logs/scraper.log"
